# Copy to .env.local (local) or set in your host's environment panel.

# --- Analytics (optional) -------------------------------------------------
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX.
# Until this is set, GA4 does NOT load and the cookie-consent banner stays
# hidden (no tracking by default — DPDP-friendly).
NEXT_PUBLIC_GA_ID=

# --- Contact form email (SMTP) -------------------------------------------
# Without these, the form still works but only logs (no email is sent).
# NOTE: use the OUTGOING/SMTP port — 465 (SSL) or 587 (STARTTLS). Port 993 is
# IMAP (incoming) and will NOT send mail.
SMTP_HOST=mail.gigawebzone.com
SMTP_PORT=465
SMTP_USER=mail@gigawebzone.com
SMTP_PASS=
# Where enquiries are delivered (defaults to SMTP_USER if unset).
CONTACT_TO=mail@gigawebzone.com

# --- CRM (added in a later phase) ----------------------------------------
# GoHighLevel branded-CRM endpoint/keys for the contact form forward.
# Left blank for now — the form works and validates without them.
# GHL_WEBHOOK_URL=
# GHL_API_KEY=
